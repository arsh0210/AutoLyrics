      "source": [
        "## 8. Decoder-Only LoRA Fine-Tuning\n",
        "\n",
        "This is the main PEFT experiment requested in `Input.md`: LoRA on the decoder attention projections."
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "id": "f02f5fd6",
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "f02f5fd6",
        "outputId": "4ae063b5-8c78-4df8-b1cd-665a5244463d"
      },
      "outputs": [
        {
          "name": "stdout",
          "output_type": "stream",
          "text": [
            "Decoder LoRA target modules: 48\n",
            "['model.decoder.layers.0.self_attn.v_proj', 'model.decoder.layers.0.self_attn.q_proj', 'model.decoder.layers.0.encoder_attn.v_proj', 'model.decoder.layers.0.encoder_attn.q_proj', 'model.decoder.layers.1.self_attn.v_proj', 'model.decoder.layers.1.self_attn.q_proj', 'model.decoder.layers.1.encoder_attn.v_proj', 'model.decoder.layers.1.encoder_attn.q_proj']\n",
            "trainable params: 1,179,648 || all params: 242,914,560 || trainable%: 0.4856\n"
          ]
        }
      ],
      "source": [
        "# Free baseline model before training a LoRA model.\n",
        "del model\n",
        "if torch.cuda.is_available():\n",
        "    torch.cuda.empty_cache()\n",
        "\n",
        "base_for_lora = WhisperForConditionalGeneration.from_pretrained(MODEL_NAME)\n",
        "base_for_lora.generation_config.language = \"english\"\n",
        "base_for_lora.generation_config.task = \"transcribe\"\n",
        "base_for_lora.generation_config.forced_decoder_ids = None\n",
        "base_for_lora.config.use_cache = False\n",
        "\n",
        "# Freeze the base model. PEFT will unfreeze the LoRA adapter weights.\n",
        "for param in base_for_lora.parameters():\n",
        "    param.requires_grad = False\n",
        "\n",
        "# Decoder-only modules are selected programmatically because PEFT target_modules\n",
        "# matches module names by suffix, not shell-style wildcards.\n",
        "decoder_lora_modules = []\n",
        "for name, module in base_for_lora.named_modules():\n",
        "    if not name.startswith(\"model.decoder.layers\"):\n",
        "        continue\n",
        "    if name.endswith((\"self_attn.q_proj\", \"self_attn.v_proj\", \"encoder_attn.q_proj\", \"encoder_attn.v_proj\")):\n",
        "        decoder_lora_modules.append(name)\n",
        "\n",
        "print(\"Decoder LoRA target modules:\", len(decoder_lora_modules))\n",
        "print(decoder_lora_modules[:8])\n",
        "\n",
        "lora_config = LoraConfig(\n",
        "    r=LORA_R,\n",
        "    lora_alpha=LORA_ALPHA,\n",
        "    lora_dropout=LORA_DROPOUT,\n",
        "    bias=\"none\",\n",
        "    target_modules=decoder_lora_modules,\n",
        ")\n",
        "\n",
        "lora_model = get_peft_model(base_for_lora, lora_config)\n",
        "lora_model.print_trainable_parameters()"
      ]
    },
