      "source": [
        "import os\n",
        "import shutil\n",
        "\n",
        "# Loop through everything in the main workspace\n",
        "for item in os.listdir('/content'):\n",
        "    item_path = os.path.join('/content', item)\n",
        "\n",
        "    # Compress only folders, skipping hidden system directories\n",
        "    if os.path.isdir(item_path) and not item.startswith('.'):\n",
        "        if item != 'sample_data':  # Optional: skip Colab's default sample data\n",
        "            shutil.make_archive(item, 'zip', item_path)\n",
        "            print(f\"Successfully zipped: {item}.zip\")\n"
      ]
    },
