            "text/plain": [
              "                          reference  \\\n",
              "0          Through days of thunders   \n",
              "1  Continuing stolid smiles to wear   \n",
              "2                    We're going on   \n",
              "3   We nearly carried it to the end   \n",
              "4                 And every whisper   \n",
              "5     And every beat of windy heart   \n",
              "6                  We're holding on   \n",
              "7      For the moment when we unite   \n",
              "8                           No face   \n",
              "9  Is seen at dusk of a raining day   \n",
              "\n",
              "                                         prediction  duration_sec  \n",
              "0                            You're getting on just          2.05  \n",
              "1                  Continues the next lines to wear          6.24  \n",
              "2                                     We don't know          2.29  \n",
              "3                    We're here to carry the Julian          4.34  \n",
              "4                                   Now you whisper          1.96  \n",
              "5                                     Never be lost          6.25  \n",
              "6                                   We are the ones          2.49  \n",
              "7              We're moments when we live your life          6.97  \n",
              "8                                         Glorified          1.95  \n",
              "9   You're the thing that drives all the way to day          3.84  "
            ]
          },
          "execution_count": 9,
          "metadata": {},
          "output_type": "execute_result"
        }
      ],
      "source": [
        "def transcribe_batch(batch, model, processor, batch_size=4, max_new_tokens=128):\n",
        "    predictions = []\n",
        "    latencies = []\n",
        "    durations = []\n",
        "\n",
        "    for start in range(0, len(batch), batch_size):\n",
        "        examples = batch.select(range(start, min(start + batch_size, len(batch))))\n",
        "        arrays = [ex[\"audio\"][\"array\"] for ex in examples]\n",
        "        durations.extend([float(ex[\"duration_sec\"]) for ex in examples])\n",
        "\n",
        "        inputs = processor(\n",
        "            arrays,\n",
        "            sampling_rate=TARGET_SR,\n",
        "            return_tensors=\"pt\",\n",
        "            padding=True,\n",
        "            return_attention_mask=True,\n",
        "        )\n",
        "        input_features = inputs.input_features.to(DEVICE, dtype=DTYPE)\n",
        "        attention_mask = inputs.get(\"attention_mask\")\n",
        "        if attention_mask is not None:\n",
        "            attention_mask = attention_mask.to(DEVICE)\n",
        "\n",
        "        t0 = time.perf_counter()\n",
        "        with torch.no_grad():\n",
        "            generated_ids = model.generate(\n",
        "                input_features,\n",
        "                attention_mask=attention_mask,\n",
        "                max_new_tokens=max_new_tokens,\n",
        "            )\n",
        "        if torch.cuda.is_available():\n",
        "            torch.cuda.synchronize()\n",
        "        elapsed = time.perf_counter() - t0\n",
        "\n",
        "        decoded = processor.batch_decode(generated_ids, skip_special_tokens=True)\n",
        "        predictions.extend(decoded)\n",
        "        latencies.extend([elapsed / len(decoded)] * len(decoded))\n",
        "\n",
        "    return predictions, latencies, durations\n",
        "\n",
        "screen_ds = test_ds.select(range(min(SCREEN_LIMIT, len(test_ds))))\n",
        "reset_cuda_peak()\n",
        "screen_predictions, screen_latencies, screen_durations = transcribe_batch(\n",
        "    screen_ds, model, processor, batch_size=PER_DEVICE_BATCH_SIZE\n",
        ")\n",
        "screen_metrics = compute_wer_cer(screen_ds[\"reference_text\"], screen_predictions)\n",
        "\n",
        "screen_summary = {\n",
        "    **screen_metrics,\n",
        "    \"examples\": len(screen_ds),\n",
        "    \"avg_latency_sec_per_clip\": float(np.mean(screen_latencies)),\n",
        "    \"audio_minutes\": float(sum(screen_durations) / 60),\n",
        "    \"latency_sec_per_audio_min\": float(sum(screen_latencies) / max(sum(screen_durations) / 60, 1e-9)),\n",
        "    \"peak_vram_gb\": cuda_peak_gb(),\n",
        "}\n",
        "print(json.dumps(screen_summary, indent=2))\n",
        "\n",
        "pd.DataFrame({\n",
        "    \"reference\": screen_ds[\"reference_text\"],\n",
        "    \"prediction\": screen_predictions,\n",
        "    \"duration_sec\": screen_durations,\n",
        "}).head(10)"
      ]
    },
