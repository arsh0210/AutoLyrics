              "9   You're the thing that drives all the way to day          3.84     0.054513  "
            ]
          },
          "execution_count": 10,
          "metadata": {},
          "output_type": "execute_result"
        }
      ],
      "source": [
        "baseline_eval_ds = test_ds\n",
        "if BASELINE_TEST_LIMIT is not None:\n",
        "    baseline_eval_ds = test_ds.select(range(min(BASELINE_TEST_LIMIT, len(test_ds))))\n",
        "\n",
        "reset_cuda_peak()\n",
        "baseline_predictions, baseline_latencies, baseline_durations = transcribe_batch(\n",
        "    baseline_eval_ds, model, processor, batch_size=PER_DEVICE_BATCH_SIZE\n",
        ")\n",
        "baseline_metrics = compute_wer_cer(baseline_eval_ds[\"reference_text\"], baseline_predictions)\n",
        "baseline_summary = {\n",
        "    **baseline_metrics,\n",
        "    \"examples\": len(baseline_eval_ds),\n",
        "    \"audio_minutes\": float(sum(baseline_durations) / 60),\n",
        "    \"avg_latency_sec_per_clip\": float(np.mean(baseline_latencies)),\n",
        "    \"latency_sec_per_audio_min\": float(sum(baseline_latencies) / max(sum(baseline_durations) / 60, 1e-9)),\n",
        "    \"peak_vram_gb\": cuda_peak_gb(),\n",
        "}\n",
        "\n",
        "baseline_df = pd.DataFrame({\n",
        "    \"example_id\": baseline_eval_ds[\"example_id\"],\n",
        "    \"song_id\": baseline_eval_ds[\"song_id\"],\n",
        "    \"reference_text\": baseline_eval_ds[\"reference_text\"],\n",
        "    \"baseline_prediction\": baseline_predictions,\n",
        "    \"duration_sec\": baseline_durations,\n",
        "    \"latency_sec\": baseline_latencies,\n",
        "})\n",
        "baseline_df.to_csv(BASELINE_PRED_PATH, index=False)\n",
        "\n",
        "print(json.dumps(baseline_summary, indent=2))\n",
        "print(\"Saved\", BASELINE_PRED_PATH)\n",
        "baseline_df.head(10)"
      ]
    },
    {
      "cell_type": "markdown",
      "id": "ff14dc94",
