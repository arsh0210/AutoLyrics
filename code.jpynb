      "source": [
        "from peft import PeftModel\n",
        "\n",
        "# Clean up trainer model from GPU first.\n",
        "del trainer\n",
        "if torch.cuda.is_available():\n",
        "    torch.cuda.empty_cache()\n",
        "\n",
        "lora_eval_model = WhisperForConditionalGeneration.from_pretrained(MODEL_NAME).to(device=DEVICE, dtype=DTYPE)\n",
        "lora_eval_model = PeftModel.from_pretrained(lora_eval_model, str(LORA_DIR)).to(DEVICE)\n",
        "lora_eval_model.eval()\n",
        "lora_eval_model.generation_config.language = \"english\"\n",
        "lora_eval_model.generation_config.task = \"transcribe\"\n",
        "lora_eval_model.generation_config.forced_decoder_ids = None\n",
        "\n",
        "reset_cuda_peak()\n",
        "lora_predictions, lora_latencies, lora_durations = transcribe_batch(\n",
        "    baseline_eval_ds, lora_eval_model, processor, batch_size=PER_DEVICE_BATCH_SIZE\n",
        ")\n",
        "lora_metrics = compute_wer_cer(baseline_eval_ds[\"reference_text\"], lora_predictions)\n",
        "relative_improvement = relative_wer_improvement(baseline_summary[\"wer\"], lora_metrics[\"wer\"])\n",
        "\n",
        "lora_summary = {\n",
        "    **lora_metrics,\n",
        "    \"relative_wer_improvement\": relative_improvement,\n",
        "    \"target_15_percent_met\": bool(relative_improvement >= 0.15),\n",
        "    \"examples\": len(baseline_eval_ds),\n",
        "    \"audio_minutes\": float(sum(lora_durations) / 60),\n",
        "    \"avg_latency_sec_per_clip\": float(np.mean(lora_latencies)),\n",
        "    \"latency_sec_per_audio_min\": float(sum(lora_latencies) / max(sum(lora_durations) / 60, 1e-9)),\n",
        "    \"peak_vram_gb\": cuda_peak_gb(),\n",
        "}\n",
        "\n",
        "comparison_df = baseline_df.copy()\n",
        "comparison_df[\"lora_prediction\"] = lora_predictions\n",
        "comparison_df[\"lora_latency_sec\"] = lora_latencies\n",
        "comparison_df.to_csv(LORA_PRED_PATH, index=False)\n",
        "\n",
        "print(\"Baseline:\", json.dumps(baseline_summary, indent=2))\n",
        "print(\"LoRA:\", json.dumps(lora_summary, indent=2))\n",
        "print(\"Saved\", LORA_PRED_PATH)\n",
        "comparison_df.head(10)"
      ]
    },
