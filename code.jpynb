              "\n",
              "   relative_wer_improvement target_15_percent_met  \n",
              "0                       NaN                   NaN  \n",
              "1                  0.401750                  True  \n",
              "2                  0.661098                  True  "
            ]
          },
          "execution_count": 22,
          "metadata": {},
          "output_type": "execute_result"
        }
      ],
      "source": [
        "metrics_summary = {\n",
        "    \"config\": {\n",
        "        \"model_name\": MODEL_NAME,\n",
        "        \"dataset_name\": DATASET_NAME,\n",
        "        \"dataset_config\": DATASET_CONFIG,\n",
        "        \"dataset_revision\": DATASET_REVISION,\n",
        "        \"lora_r\": LORA_R,\n",
        "        \"lora_alpha\": LORA_ALPHA,\n",
        "        \"lora_dropout\": LORA_DROPOUT,\n",
        "        \"learning_rate\": LEARNING_RATE,\n",
        "        \"epochs\": NUM_EPOCHS,\n",
        "        \"batch_size\": PER_DEVICE_BATCH_SIZE,\n",
        "        \"gradient_accumulation_steps\": GRADIENT_ACCUMULATION_STEPS,\n",
        "    },\n",
        "    \"screening\": screen_summary,\n",
        "    \"baseline\": baseline_summary,\n",
        "    \"lora_decoder\": lora_summary,\n",
        "    \"lora_encoder_decoder\": encdec_summary if \"encdec_summary\" in globals() else None,\n",
        "    \"training\": train_summary,\n",
        "}\n",
        "REPORT_PATH.write_text(json.dumps(metrics_summary, indent=2))\n",
        "print(\"Saved\", REPORT_PATH)\n",
        "\n",
        "summary_rows = [\n",
        "    {\"approach\": \"zero_shot_whisper\", **baseline_summary},\n",
        "    {\"approach\": \"decoder_lora\", **lora_summary},\n",
        "]\n",
        "if \"encdec_summary\" in globals():\n",
        "    summary_rows.append({\"approach\": \"encoder_decoder_lora\", **encdec_summary})\n",
        "\n",
        "summary_table = pd.DataFrame(summary_rows)\n",
        "summary_table"
      ]
    },
    {
      "cell_type": "markdown",
      "id": "69ff11f2",
      "metadata": {
        "id": "69ff11f2"
      },
      "source": [
        "## 12. Optional Gradio Demo\n",
        "\n",
        "Run after training to compare base Whisper and the LoRA adapter on an uploaded music clip."
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "id": "75f13a8c",
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/",
          "height": 1000
        },
        "id": "75f13a8c",
        "outputId": "cfbf763e-d55f-4ee0-817d-88385167f080"
      },
      "outputs": [],
      "source": [
        "RUN_GRADIO_DEMO = False\n",
        "\n",
        "if RUN_GRADIO_DEMO:\n",
        "    import gradio as gr\n",
        "    import librosa\n",
        "\n",
        "    base_demo_model = WhisperForConditionalGeneration.from_pretrained(MODEL_NAME).to(device=DEVICE, dtype=DTYPE).eval()\n",
        "    base_demo_model.generation_config.language = \"english\"\n",
        "    base_demo_model.generation_config.task = \"transcribe\"\n",
        "    base_demo_model.generation_config.forced_decoder_ids = None\n",
        "\n",
        "    tuned_demo_model = WhisperForConditionalGeneration.from_pretrained(MODEL_NAME).to(device=DEVICE, dtype=DTYPE)\n",
        "    tuned_demo_model = PeftModel.from_pretrained(tuned_demo_model, str(LORA_DIR)).to(DEVICE).eval()\n",
        "    tuned_demo_model.generation_config.language = \"english\"\n",
        "    tuned_demo_model.generation_config.task = \"transcribe\"\n",
        "    tuned_demo_model.generation_config.forced_decoder_ids = None\n",
        "\n",
        "    def transcribe_file(path):\n",
        "        audio, _ = librosa.load(path, sr=TARGET_SR, mono=True)\n",
        "        audio = audio[: TARGET_SR * 28]\n",
        "        inputs = processor(audio, sampling_rate=TARGET_SR, return_tensors=\"pt\")\n",
        "        feats = inputs.input_features.to(DEVICE, dtype=DTYPE)\n",
        "        with torch.no_grad():\n",
        "            base_ids = base_demo_model.generate(feats, max_new_tokens=128)\n",
        "            tuned_ids = tuned_demo_model.generate(feats, max_new_tokens=128)\n",
        "        base_text = processor.batch_decode(base_ids, skip_special_tokens=True)[0]\n",
        "        tuned_text = processor.batch_decode(tuned_ids, skip_special_tokens=True)[0]\n",
        "        return base_text, tuned_text\n",
        "\n",
        "    demo = gr.Interface(\n",
        "        fn=transcribe_file,\n",
        "        inputs=gr.Audio(type=\"filepath\", label=\"Upload a short music clip\"),\n",
        "        outputs=[gr.Textbox(label=\"Baseline Whisper\"), gr.Textbox(label=\"LoRA Whisper\")],\n",
        "        title=\"AutoLyrics: Baseline vs LoRA Whisper\",\n",
        "    )\n",
        "    demo.launch(debug=True)\n",
        "else:\n",
        "    print(\"Skipped Gradio demo. Set RUN_GRADIO_DEMO=True after training to launch it.\")"
      ]
    }
  ],
