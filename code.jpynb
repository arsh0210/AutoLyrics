      "source": [
        "manifest = build_line_manifest(raw_dataset)\n",
        "manifest = split_manifest_by_song(manifest)\n",
        "manifest.to_csv(MANIFEST_PATH, index=False)\n",
        "\n",
        "print(\"Saved manifest:\", MANIFEST_PATH)\n",
        "print(\"Examples:\", len(manifest))\n",
        "print(\"Songs:\", manifest[\"song_id\"].nunique())\n",
        "print(manifest.groupby(\"split\").agg(\n",
        "    examples=(\"example_id\", \"count\"),\n",
        "    songs=(\"song_id\", \"nunique\"),\n",
        "    minutes=(\"duration_sec\", lambda x: round(x.sum()/60, 2)),\n",
        "))\n",
        "manifest.head()"
      ]
    },
    {
      "cell_type": "markdown",
      "id": "SyeOy6AjfV1o",
      "metadata": {
        "id": "SyeOy6AjfV1o"
      },
      "source": [
        "## 4. Build Segment Dataset Objects\n",
        "\n",
        "The manifest stores timing metadata. This cell slices the original song audio into short line-level examples."
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "id": "JOSS50A1fV1o",
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "JOSS50A1fV1o",
        "outputId": "0021446c-f376-45f1-e748-2afa38931110"
      },
      "outputs": [
        {
          "name": "stdout",
          "output_type": "stream",
          "text": [
            "Dataset({\n",
            "    features: ['example_id', 'song_id', 'audio', 'reference_text', 'duration_sec'],\n",
            "    num_rows: 706\n",
            "})\n",
            "Dataset({\n",
            "    features: ['example_id', 'song_id', 'audio', 'reference_text', 'duration_sec'],\n",
            "    num_rows: 125\n",
            "})\n",
            "Dataset({\n",
            "    features: ['example_id', 'song_id', 'audio', 'reference_text', 'duration_sec'],\n",
            "    num_rows: 141\n",
            "})\n"
          ]
        }
      ],
      "source": [
        "def make_segment_dataset(manifest_df, split_name):\n",
        "    subset = manifest_df[manifest_df[\"split\"] == split_name].reset_index(drop=True)\n",
        "    records = []\n",
        "    for _, row in subset.iterrows():\n",
        "        source = raw_dataset[int(row[\"source_row\"])]\n",
        "        segment, sr = get_audio_segment(source[\"audio\"], float(row[\"start\"]), float(row[\"end\"]))\n",
        "        records.append({\n",
        "            \"example_id\": row[\"example_id\"],\n",
        "            \"song_id\": row[\"song_id\"],\n",
        "            \"audio\": {\"array\": segment, \"sampling_rate\": sr},\n",
        "            \"reference_text\": row[\"reference_text\"],\n",
        "            \"duration_sec\": float(row[\"duration_sec\"]),\n",
        "        })\n",
        "    return Dataset.from_list(records).cast_column(\"audio\", Audio(sampling_rate=TARGET_SR))\n",
        "\n",
        "train_ds = make_segment_dataset(manifest, \"train\")\n",
        "val_ds = make_segment_dataset(manifest, \"validation\")\n",
        "test_ds = make_segment_dataset(manifest, \"test\")\n",
        "\n",
        "if MAX_TRAIN_EXAMPLES is not None:\n",
        "    train_ds = train_ds.select(range(min(MAX_TRAIN_EXAMPLES, len(train_ds))))\n",
        "\n",
        "print(train_ds)\n",
        "print(val_ds)\n",
        "print(test_ds)"
      ]
    },
    {
      "cell_type": "markdown",
      "id": "TMmsRi8vfV1o",
      "metadata": {
        "id": "TMmsRi8vfV1o"
      },
      "source": [
        "## 5. Load Whisper and Run Dataset Screening\n",
        "\n",
        "Screening answers: does Whisper fail enough on this dataset to justify fine-tuning?\n",
        "\n",
        "A useful dataset should have baseline WER roughly in the `40%-90%` range and references that are visibly valid lyrics."
      ]
    },
