      "source": [
        "if not ENCDEC_LORA_DIR.exists():\n",
        "    raise FileNotFoundError(\n",
        "        f\"Encoder+decoder LoRA adapter not found at {ENCDEC_LORA_DIR}. \"\n",
        "        \"Train it first by setting RUN_ENCODER_DECODER_LORA=True and running section 10.\"\n",
        "    )\n",
        "\n",
        "# Clean up previous evaluation model from GPU first if it exists.\n",
        "if \"lora_eval_model\" in globals():\n",
        "    del lora_eval_model\n",
        "if \"encdec_eval_model\" in globals():\n",
        "    del encdec_eval_model\n",
        "if torch.cuda.is_available():\n",
        "    torch.cuda.empty_cache()\n",
        "\n",
        "encdec_eval_model = WhisperForConditionalGeneration.from_pretrained(MODEL_NAME).to(device=DEVICE, dtype=DTYPE)\n",
        "encdec_eval_model = PeftModel.from_pretrained(encdec_eval_model, str(ENCDEC_LORA_DIR)).to(DEVICE)\n",
        "encdec_eval_model.eval()\n",
        "encdec_eval_model.generation_config.language = \"english\"\n",
        "encdec_eval_model.generation_config.task = \"transcribe\"\n",
        "encdec_eval_model.generation_config.forced_decoder_ids = None\n",
        "\n",
        "reset_cuda_peak()\n",
        "encdec_predictions, encdec_latencies, encdec_durations = transcribe_batch(\n",
        "    baseline_eval_ds, encdec_eval_model, processor, batch_size=PER_DEVICE_BATCH_SIZE\n",
        ")\n",
        "encdec_metrics = compute_wer_cer(baseline_eval_ds[\"reference_text\"], encdec_predictions)\n",
        "encdec_relative_improvement = relative_wer_improvement(baseline_summary[\"wer\"], encdec_metrics[\"wer\"])\n",
        "\n",
        "encdec_summary = {\n",
        "    **encdec_metrics,\n",
        "    \"relative_wer_improvement\": encdec_relative_improvement,\n",
        "    \"target_15_percent_met\": bool(encdec_relative_improvement >= 0.15),\n",
        "    \"examples\": len(baseline_eval_ds),\n",
        "    \"audio_minutes\": float(sum(encdec_durations) / 60),\n",
        "    \"avg_latency_sec_per_clip\": float(np.mean(encdec_latencies)),\n",
        "    \"latency_sec_per_audio_min\": float(sum(encdec_latencies) / max(sum(encdec_durations) / 60, 1e-9)),\n",
        "    \"peak_vram_gb\": cuda_peak_gb(),\n",
        "}\n",
        "\n",
        "encdec_comparison_df = baseline_df.copy()\n",
        "encdec_comparison_df[\"encoder_decoder_lora_prediction\"] = encdec_predictions\n",
        "encdec_comparison_df[\"encoder_decoder_lora_latency_sec\"] = encdec_latencies\n",
        "encdec_comparison_df.to_csv(ENCDEC_LORA_PRED_PATH, index=False)\n",
        "\n",
        "print(\"Baseline:\", json.dumps(baseline_summary, indent=2))\n",
        "print(\"Encoder+Decoder LoRA:\", json.dumps(encdec_summary, indent=2))\n",
        "print(\"Saved\", ENCDEC_LORA_PRED_PATH)\n",
        "encdec_comparison_df.head(10)"
      ]
    },
    {
      "cell_type": "markdown",
      "id": "7c7d0bd9",
