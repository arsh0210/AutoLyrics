          "text": [
            "Saved encoder+decoder LoRA adapter to autolyrics_outputs/whisper_small_lora_encoder_decoder\n"
          ]
        }
      ],
      "source": [
        "RUN_ENCODER_DECODER_LORA = True\n",
        "\n",
        "if RUN_ENCODER_DECODER_LORA:\n",
        "    encdec_dir = OUTPUT_DIR / \"whisper_small_lora_encoder_decoder\"\n",
        "    if torch.cuda.is_available():\n",
        "        torch.cuda.empty_cache()\n",
        "\n",
        "    encdec_base = WhisperForConditionalGeneration.from_pretrained(MODEL_NAME)\n",
        "    encdec_base.generation_config.language = \"english\"\n",
        "    encdec_base.generation_config.task = \"transcribe\"\n",
        "    encdec_base.generation_config.forced_decoder_ids = None\n",
        "    encdec_base.config.use_cache = False\n",
        "    for param in encdec_base.parameters():\n",
        "        param.requires_grad = False\n",
        "\n",
        "    encdec_lora_modules = []\n",
        "    for name, module in encdec_base.named_modules():\n",
        "        if not name.startswith((\"model.encoder.layers\", \"model.decoder.layers\")):\n",
        "            continue\n",
        "        if name.endswith((\"self_attn.q_proj\", \"self_attn.v_proj\", \"encoder_attn.q_proj\", \"encoder_attn.v_proj\")):\n",
        "            encdec_lora_modules.append(name)\n",
        "\n",
        "    encdec_config = LoraConfig(\n",
        "        r=LORA_R,\n",
        "        lora_alpha=LORA_ALPHA,\n",
        "        lora_dropout=LORA_DROPOUT,\n",
        "        bias=\"none\",\n",
        "        target_modules=encdec_lora_modules,\n",
        "    )\n",
        "    encdec_model = get_peft_model(encdec_base, encdec_config)\n",
        "    encdec_model.print_trainable_parameters()\n",
        "\n",
        "    encdec_args = Seq2SeqTrainingArguments(\n",
        "        output_dir=str(encdec_dir),\n",
        "        per_device_train_batch_size=PER_DEVICE_BATCH_SIZE,\n",
        "        per_device_eval_batch_size=PER_DEVICE_BATCH_SIZE,\n",
        "        gradient_accumulation_steps=GRADIENT_ACCUMULATION_STEPS,\n",
        "        learning_rate=LEARNING_RATE,\n",
        "        num_train_epochs=NUM_EPOCHS,\n",
        "        fp16=torch.cuda.is_available(),\n",
        "        eval_strategy=\"epoch\",\n",
        "        save_strategy=\"epoch\",\n",
        "        logging_steps=10,\n",
        "        remove_unused_columns=False,\n",
        "        label_names=[\"labels\"],\n",
        "        report_to=\"none\",\n",
        "        seed=SEED,\n",
        "    )\n",
        "    encdec_trainer = Seq2SeqTrainer(\n",
        "        args=encdec_args,\n",
        "        model=encdec_model,\n",
        "        train_dataset=train_prepared,\n",
        "        eval_dataset=val_prepared,\n",
        "        data_collator=collator,\n",
        "        tokenizer=processor.feature_extractor,\n",
        "    )\n",
        "    encdec_trainer.train()\n",
        "    encdec_trainer.save_model(str(encdec_dir))\n",
        "    processor.save_pretrained(str(encdec_dir))\n",
        "    print(\"Saved encoder+decoder LoRA adapter to\", encdec_dir)\n",
        "else:\n",
        "    print(\"Skipped encoder+decoder LoRA. Set RUN_ENCODER_DECODER_LORA=True to run it.\")"
      ]
    },
    {
