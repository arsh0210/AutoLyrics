      "source": [
        "## 1. Configuration\n",
        "\n",
        "The defaults are intentionally small enough for Colab T4. Increase `SCREEN_LIMIT`, `BASELINE_TEST_LIMIT`, and `MAX_TRAIN_EXAMPLES` after the first successful run."
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "id": "1gvvez8RfV1m",
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "1gvvez8RfV1m",
        "outputId": "8ad25609-5114-46f9-cd56-86a6e8eca409"
      },
      "outputs": [
        {
          "name": "stdout",
          "output_type": "stream",
          "text": [
            "Outputs will be written under /content/autolyrics_outputs\n"
          ]
        }
      ],
      "source": [
        "MODEL_NAME = \"openai/whisper-small\"\n",
        "DATASET_NAME = \"jamendolyrics/jam-alt\"\n",
        "DATASET_CONFIG = \"en\"          # English subset first; switch to \"all\" only for multilingual experiments.\n",
        "DATASET_REVISION = \"v1.4.0\"    # Dataset card uses this revision for benchmark examples.\n",
        "TARGET_SR = 16_000\n",
        "\n",
        "# Dataset screening controls\n",
        "SCREEN_LIMIT = 30              # 20-60 per plan. Keep 30 for first Colab run.\n",
        "BASELINE_TEST_LIMIT = None     # None = full test split. Use a small number for a smoke test.\n",
        "MAX_TRAIN_EXAMPLES = None      # None = all training segments. Use 200 for a fast smoke test.\n",
        "\n",
        "# Segment controls. Whisper trains best on <=30s examples.\n",
        "MAX_SEGMENT_SECONDS = 28.0\n",
        "MIN_SEGMENT_SECONDS = 1.0\n",
        "SEGMENT_PADDING_SECONDS = 0.20\n",
        "\n",
        "# Training controls\n",
        "OUTPUT_DIR = Path(\"autolyrics_outputs\")\n",
        "MANIFEST_PATH = OUTPUT_DIR / \"jam_alt_line_manifest.csv\"\n",
        "BASELINE_PRED_PATH = OUTPUT_DIR / \"baseline_predictions.csv\"\n",
        "LORA_PRED_PATH = OUTPUT_DIR / \"lora_predictions.csv\"\n",
        "LORA_DIR = OUTPUT_DIR / \"whisper_small_lora_decoder\"\n",
        "REPORT_PATH = OUTPUT_DIR / \"metrics_summary.json\"\n",
        "\n",
        "LORA_R = 16\n",
        "LORA_ALPHA = 32\n",
        "LORA_DROPOUT = 0.05\n",
        "LEARNING_RATE = 1e-4\n",
        "NUM_EPOCHS = 8\n",
        "PER_DEVICE_BATCH_SIZE = 4\n",
        "GRADIENT_ACCUMULATION_STEPS = 2\n",
        "\n",
        "OUTPUT_DIR.mkdir(parents=True, exist_ok=True)\n",
        "print(\"Outputs will be written under\", OUTPUT_DIR.resolve())"
      ]
    },
    {
      "cell_type": "markdown",
      "id": "E0Aa_igrfV1m",
      "metadata": {
        "id": "E0Aa_igrfV1m"
      },
      "source": [
        "## 2. Utilities\n",
        "\n",
        "These helpers normalize lyrics, compute metrics, measure memory/latency, find Jam-ALT line timings, and segment full songs into line-level training examples."
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "id": "WM3y1GivfV1m",
      "metadata": {
        "id": "WM3y1GivfV1m"
      },
      "outputs": [],
      "source": [
        "import numpy as np\n",
        "import pandas as pd\n",
        "import datasets\n",
        "from datasets import load_dataset, Audio, Dataset\n",
        "from jiwer import wer, cer\n",
        "\n",
        "\n",
        "def clean_text(text: str) -> str:\n",
        "    \"\"\"Normalize text for fair WER/CER without destroying lyrics content.\"\"\"\n",
        "    if text is None:\n",
        "        return \"\"\n",
        "    text = str(text).lower()\n",
        "    text = re.sub(r\"\\[[^\\]]+\\]\", \" \", text)          # remove bracketed tags\n",
        "    text = re.sub(r\"\\([^)]*instrumental[^)]*\\)\", \" \", text)\n",
        "    text = re.sub(r\"[^a-z0-9'\\n ]+\", \" \", text)\n",
        "    text = re.sub(r\"\\s+\", \" \", text).strip()\n",
        "    return text\n",
        "\n",
        "\n",
        "def compute_wer_cer(references, hypotheses):\n",
        "    refs = [clean_text(x) for x in references]\n",
        "    hyps = [clean_text(x) for x in hypotheses]\n",
        "    return {\n",
        "        \"wer\": float(wer(refs, hyps)),\n",
        "        \"cer\": float(cer(refs, hyps)),\n",
        "    }\n",
        "\n",
        "\n",
        "def relative_wer_improvement(baseline_wer, tuned_wer):\n",
        "    if baseline_wer <= 0:\n",
        "        return 0.0\n",
        "    return float((baseline_wer - tuned_wer) / baseline_wer)\n",
        "\n",
        "\n",
        "def cuda_peak_gb():\n",
        "    if not torch.cuda.is_available():\n",
        "        return None\n",
        "    return torch.cuda.max_memory_allocated() / (1024 ** 3)\n",
        "\n",
        "\n",
        "def reset_cuda_peak():\n",
        "    if torch.cuda.is_available():\n",
        "        torch.cuda.empty_cache()\n",
        "        torch.cuda.reset_peak_memory_stats()\n",
        "\n",
        "\n",
        "def _samples_to_numpy(samples):\n",
        "    \"\"\"Convert torchcodec AudioSamples or array-like audio to mono numpy.\"\"\"\n",
        "    data = samples.data if hasattr(samples, \"data\") else samples\n",
        "    if hasattr(data, \"detach\"):\n",
        "        data = data.detach().cpu().numpy()\n",
        "    audio = np.asarray(data, dtype=np.float32)\n",
        "    sr = int(getattr(samples, \"sample_rate\", TARGET_SR))\n",
        "\n",
        "    # TorchCodec uses (channels, samples); other loaders may use (samples, channels).\n",
        "    if audio.ndim == 2:\n",
        "        if audio.shape[0] <= 8:\n",
        "            audio = audio.mean(axis=0)\n",
        "        else:\n",
        "            audio = audio.mean(axis=1)\n",
        "    return audio, sr\n",
        "\n",
        "\n",
        "def get_audio_array(audio_obj):\n",
        "    # Newer datasets returns torchcodec AudioDecoder. Decode explicitly.\n",
        "    if hasattr(audio_obj, \"get_all_samples\"):\n",
        "        return _samples_to_numpy(audio_obj.get_all_samples())\n",
        "\n",
        "    # Older datasets returns {array, sampling_rate, path}.\n",
        "    if isinstance(audio_obj, dict):\n",
        "        audio = np.asarray(audio_obj[\"array\"], dtype=np.float32)\n",
        "        sr = int(audio_obj[\"sampling_rate\"])\n",
        "        if audio.ndim == 2:\n",
        "            if audio.shape[0] <= 8:\n",
        "                audio = audio.mean(axis=0)\n",
        "            else:\n",
        "                audio = audio.mean(axis=1)\n",
        "        return audio, sr\n",
        "\n",
        "    return _samples_to_numpy(audio_obj)\n",
        "\n",
        "\n",
        "def get_audio_duration(audio_obj):\n",
        "    if hasattr(audio_obj, \"metadata\") and getattr(audio_obj.metadata, \"duration_seconds\", None):\n",
        "        return float(audio_obj.metadata.duration_seconds)\n",
        "    audio, sr = get_audio_array(audio_obj)\n",
        "    return len(audio) / sr\n",
        "\n",
        "\n",
        "def get_audio_segment(audio_obj, start, end):\n",
        "    # Decode only the requested range when using torchcodec.\n",
        "    if hasattr(audio_obj, \"get_samples_played_in_range\"):\n",
        "        return _samples_to_numpy(audio_obj.get_samples_played_in_range(start, end))\n",
        "    audio, sr = get_audio_array(audio_obj)\n",
        "    start_i = int(float(start) * sr)\n",
        "    end_i = int(float(end) * sr)\n",
        "    return audio[start_i:end_i].astype(np.float32), sr\n",
        "\n",
        "\n",
        "def get_song_id(row, index):\n",
        "    for key in [\"name\", \"track_id\", \"file_name\", \"audio\"]:\n",
        "        if key in row and row[key] is not None:\n",
        "            value = row[key]\n",
        "            if isinstance(value, dict) and value.get(\"path\"):\n",
        "                return Path(value[\"path\"]).stem\n",
        "            return Path(str(value)).stem.replace(\" \", \"_\")\n",
        "    artist = str(row.get(\"artist\", \"unknown_artist\"))\n",
        "    title = str(row.get(\"title\", f\"song_{index}\"))\n",
        "    return re.sub(r\"[^A-Za-z0-9_]+\", \"_\", f\"{artist}_{title}\").strip(\"_\")\n",
        "\n",
        "\n",
        "def extract_line_timings(row):\n",
        "    \"\"\"Find Jam-ALT line timing list across likely column names.\n",
        "\n",
        "    Hugging Face datasets can return nested lines either as:\n",
        "    - list[dict]: [{\"start\": ..., \"end\": ..., \"text\": ...}, ...]\n",
        "    - dict[list]: {\"start\": [...], \"end\": [...], \"text\": [...]}\n",
        "    \"\"\"\n",
        "    candidates = [\"lines\", \"line_timings\", \"timings\", \"segments\", \"alignment\"]\n",
        "    for key in candidates:\n",
        "        value = row.get(key)\n",
        "        if isinstance(value, list) and value:\n",
        "            first = value[0]\n",
        "            if isinstance(first, dict) and {\"start\", \"end\", \"text\"}.issubset(first.keys()):\n",
        "                return value\n",
        "        if isinstance(value, dict) and {\"start\", \"end\", \"text\"}.issubset(value.keys()):\n",
        "            return [\n",
        "                {\"start\": start, \"end\": end, \"text\": text}\n",
        "                for start, end, text in zip(value[\"start\"], value[\"end\"], value[\"text\"])\n",
        "            ]\n",
        "    return []\n",
        "\n",
        "\n",
        "def build_line_manifest(raw_ds, max_songs=None):\n",
        "    rows = []\n",
        "    iterable = list(raw_ds)\n",
        "    if max_songs is not None:\n",
        "        iterable = iterable[:max_songs]\n",
        "\n",
        "    for song_idx, row in enumerate(iterable):\n",
        "        song_id = get_song_id(row, song_idx)\n",
        "        language = row.get(\"language\", DATASET_CONFIG)\n",
        "        full_text = row.get(\"text\", \"\")\n",
        "        duration = get_audio_duration(row[\"audio\"])\n",
        "        line_timings = extract_line_timings(row)\n",
        "\n",
        "        if not line_timings:\n",
        "            # Fallback: use the first <=28s audio chunk with the full reference.\n",
        "            rows.append({\n",
        "                \"example_id\": f\"{song_id}__chunk0\",\n",
        "                \"song_id\": song_id,\n",
        "                \"language\": language,\n",
        "                \"start\": 0.0,\n",
        "                \"end\": min(duration, MAX_SEGMENT_SECONDS),\n",
        "                \"duration_sec\": min(duration, MAX_SEGMENT_SECONDS),\n",
        "                \"reference_text\": full_text,\n",
        "                \"source_row\": song_idx,\n",
        "            })\n",
        "            continue\n",
        "\n",
        "        for line_idx, line in enumerate(line_timings):\n",
        "            text = str(line.get(\"text\", \"\")).strip()\n",
        "            start = float(line.get(\"start\", 0.0))\n",
        "            end = float(line.get(\"end\", start))\n",
        "            if not clean_text(text):\n",
        "                continue\n",
        "            start = max(0.0, start - SEGMENT_PADDING_SECONDS)\n",
        "            end = min(duration, end + SEGMENT_PADDING_SECONDS)\n",
        "            seg_dur = end - start\n",
        "            if seg_dur < MIN_SEGMENT_SECONDS or seg_dur > MAX_SEGMENT_SECONDS:\n",
        "                continue\n",
        "            rows.append({\n",
        "                \"example_id\": f\"{song_id}__line{line_idx:04d}\",\n",
        "                \"song_id\": song_id,\n",
        "                \"language\": language,\n",
        "                \"start\": start,\n",
        "                \"end\": end,\n",
        "                \"duration_sec\": seg_dur,\n",
        "                \"reference_text\": text,\n",
        "                \"source_row\": song_idx,\n",
        "            })\n",
        "\n",
        "    manifest = pd.DataFrame(rows)\n",
        "    if manifest.empty:\n",
        "        raise RuntimeError(\"No usable lyric segments were found. Inspect dataset columns and line timing fields.\")\n",
        "    return manifest\n",
        "\n",
        "\n",
        "def split_manifest_by_song(manifest, train_ratio=0.70, val_ratio=0.15, seed=SEED):\n",
        "    rng = random.Random(seed)\n",
        "    songs = sorted(manifest[\"song_id\"].unique())\n",
        "    rng.shuffle(songs)\n",
        "    n = len(songs)\n",
        "    n_train = max(1, int(round(n * train_ratio)))\n",
        "    n_val = max(1, int(round(n * val_ratio))) if n >= 3 else 0\n",
        "    train_songs = set(songs[:n_train])\n",
        "    val_songs = set(songs[n_train:n_train + n_val])\n",
        "    test_songs = set(songs[n_train + n_val:])\n",
        "    if not test_songs and val_songs:\n",
        "        test_songs.add(val_songs.pop())\n",
        "\n",
        "    def assign(song_id):\n",
        "        if song_id in train_songs:\n",
        "            return \"train\"\n",
        "        if song_id in val_songs:\n",
        "            return \"validation\"\n",
        "        return \"test\"\n",
        "\n",
        "    manifest = manifest.copy()\n",
        "    manifest[\"split\"] = manifest[\"song_id\"].map(assign)\n",
        "    return manifest"
      ]
    },
    {
      "cell_type": "markdown",
      "id": "Ov9KLhFQfV1n",
      "metadata": {
        "id": "Ov9KLhFQfV1n"
      },
      "source": [
        "## 3. Load Jam-ALT and Build a Line-Level Manifest\n",
        "\n",
        "This normalizes Jam-ALT into the schema required by the plan:\n",
        "\n",
        "`audio`, `reference_text`, `song_id`, `duration_sec`, `split`\n",
        "\n",
        "The Hugging Face dataset stores full songs. We use line timings to cut them into short examples suitable for Whisper training."
      ]
    },
